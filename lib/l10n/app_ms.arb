  "ending_landscapeAtmoLow": "Tekanan atmosfera sangat rendah secara berbahaya — habitat tertutup amat diperlukan. ",
  "ending_landscapeGravityWells": "Poket graviti terherot bertitik di permukaan — batu terapung di udara dan sungai mengalir ke atas sebelum terhempas turun di tepi anomali. ",
  "ending_landscapeSubspaceEchoes": "Sesuatu bergema di bawah permukaan — dengung rendah yang dirasai dalam tulang dan bukan didengari, seolah-olah planet itu sendiri mengingati sesuatu yang purba dan luas. ",
  "ending_landscapeNotableFeature": "Ciri ketara: {feature}.",
  "ending_landscapeNotableFeatures": "Ciri-ciri ketara: {features}.",
  "ending_govSentenceDemocracy": "Kolonis {planetName} menubuhkan kerajaan demokratik, dengan wakil yang dipilih membimbing tamadun baharu melalui tahun-tahun pembentukannya.",
  "ending_govSentenceTechnocracy": "Kuasa di {planetName} jatuh kepada jurutera dan saintis yang mengekalkan koloni hidup, membentuk majlis teknokratik yang mentadbir melalui kepakaran dan pragmatisme.",
  "ending_govSentenceRepublic": "Piagam republik dirangka pada tahun pertama di {planetName}, mengimbangi suara kolonis dengan senat pemimpin yang dilantik.",
  "ending_govSentenceAutocracy": "Dengan institusi budaya yang runtuh, kuasa di {planetName} disatukan di bawah seorang pemimpin kuat yang mengenakan ketenteraman melalui keperluan dan kekuatan tekad.",
  "ending_govSentenceTribalCouncil": "Segelintir mangsa selamat di {planetName} mengorganisasi diri menjadi klan kecil, ditadbir oleh majlis tetua yang membuat keputusan di sekeliling api bersama.",
  "ending_govSentenceDefault": "Kolonis {planetName} mengorganisasi diri mereka sebaik mungkin.",
  "ending_constructionSentenceAdvanced": "Sistem pembinaan canggih membolehkan kolonis {colonyName} mendirikan struktur kekal dalam beberapa minggu selepas mendarat, lengkap dengan habitat bertekanan dan infrastruktur.",
  "ending_constructionSentenceFunctional": "Peralatan pembinaan koloni, rosak tetapi berfungsi, menghasilkan tempat perlindungan kukuh dan jalan asas merentasi penempatan.",
  "ending_constructionSentencePrimitive": "Dengan sistem pembinaan yang hampir tidak beroperasi, peneroka membina tempat perlindungan kasar dari badan kapal salvaj dan bahan tempatan.",
  "ending_constructionSentenceNone": "Tanpa peralatan pembinaan yang berfungsi, kolonis berhimpit dalam serpihan kapal itu sendiri, tidak mampu membina apa-apa yang baharu.",
  "ending_constructionSentenceDefault": "Kolonis membina apa yang mampu dengan apa yang ada.",
  "ending_moonMetalRichLowRes": "Bulan kaya logam yang mengorbit di atas menjadi penyelamat koloni — ekspedisi perlombongan ke permukaannya menyediakan bahan mentah yang planet itu sendiri tidak mampu berikan.",
  "ending_moonMetalRichHighRes": "Bulan kaya logam planet ini menyediakan pelengkap yang dialu-alukan kepada sumber mineral yang sudah mencukupi, memacu kemajuan teknologi yang pantas.",
  "ending_moonUnstable": "Bulan tidak stabil dalam orbit yang merosot menghujani koloni dengan serpihan, memusnahkan infrastruktur dan menghancurkan teknologi yang tidak boleh diganti dalam bombardiran meteor berkala.",
  "ending_culturePhrase_renaissance": "Tradisi seni dan sastera Bumi bukan sahaja bertahan tetapi mekar menjadi kebangkitan",
  "ending_culturePhrase_preserved": "Kolonis memelihara banyak warisan budaya Bumi, mengekalkan perpustakaan dan tradisi",
  "ending_culturePhrase_fragmented": "Hanya serpihan budaya Bumi yang bertahan — lagu dan cerita yang separuh diingat, disampaikan dari mulut ke mulut",
  "ending_culturePhrase_lost": "Budaya Bumi hampir dilupakan, digantikan oleh pragmatisme brutal kelangsungan hidup",
  "ending_culturePhrase_default": "Warisan budaya Bumi mengambil bentuk yang baharu",
  "ending_techPhrase_advanced": "manakala teknologi canggih dari kapal membolehkan koloni membina tamadun moden dengan elektrik, perubatan, dan rangkaian komunikasi.",
  "ending_techPhrase_industrial": "dan koloni mencapai tahap teknologi perindustrian, dengan tempaan, kilang, dan pembuatan asas mengekalkan populasi yang berkembang.",
  "ending_techPhrase_preIndustrial": "walaupun teknologi mundur ke keadaan pra-perindustrian, dengan alat tangan dan tenaga haiwan membentuk tulang belakang kehidupan harian.",
  "ending_techPhrase_stoneAge": "dan tanpa cara untuk membina semula, koloni tergelincir ke kewujudan zaman batu, membuat alat dari batu dan tulang.",
  "ending_techPhrase_default": "dan teknologi menetap pada tahap yang mampu dikekalkan oleh kolonis.",
  "ending_populationHigh": "Hampir semua {colonists} kolonis terselamat dalam pelayaran, memberikan {colonyName} asas modal insan yang kukuh.",
  "ending_populationMedium": "Daripada seribu yang asal, {colonists} kolonis sampai ke {colonyName} — cukup untuk mengekalkan populasi yang berdaya maju.",
  "ending_populationLow": "Hanya {colonists} kolonis yang terselamat untuk sampai ke {colonyName}, kumpulan gen yang amat kecil untuk tamadun baharu.",
  "ending_populationCritical": "Hanya {colonists} jiwa yang tiba di {colonyName} — hampir tidak cukup untuk dipanggil koloni, lebih kepada pertahanan terakhir yang terdesak.",
  "ending_nativeSentenceIntegrated": "Penduduk asal {planetName} menyambut peneroka, dan dalam satu generasi kedua-dua kaum telah bergabung menjadi masyarakat bersama, lebih kaya kerana percampuran tradisi.",
  "ending_nativeSentenceCoexistence": "Kolonis dan penduduk asal {planetName} mengekalkan kewujudan bersama yang berhati-hati tetapi damai, berdagang pengetahuan dan sumber merentasi sempadan budaya.",
  "ending_nativeSentenceTension": "Hubungan dengan penduduk asal {planetName} kekal tegang, ditandai oleh salah faham dan pertikaian wilayah yang membayangi masa depan koloni.",
  "ending_nativeSentenceConflict": "Konflik terbuka dengan tamadun asal {planetName} mentakrifkan sejarah awal koloni, menguras sumber dan nyawa dari kedua-dua pihak dalam perjuangan yang tidak mampu dimenangi sepenuhnya oleh sesiapa.",
  "ending_outlookGoldenAge": "Bersendirian di {planetName} dan tidak dibebani konflik, koloni mencartakan haluannya sendiri ke arah masa depan yang cerah di antara bintang-bintang.",
  "ending_outlookThrivingColony": "Tanpa persaingan peribumi, kolonis merebak merentasi permukaan {planetName}, membina pekan dan jalan yang menyambungkan rangkaian penempatan yang berkembang.",
  "ending_outlookSurvival": "Dunia kosong itu tidak menawarkan sekutu tetapi juga tiada musuh, dan kolonis mengukir niche mereka dalam kesunyian landskap luas {planetName}.",
  "ending_outlookStruggling": "Kesunyian tandus {planetName} tidak menawarkan kolonis bantuan mahupun keselesaan, hanya kesunyian acuh dunia asing.",
  "ending_outlookDire": "Di dunia yang kosong daripada kehidupan pintar lain, mangsa selamat terakhir hanya mempunyai satu sama lain dan harapan yang semakin pudar bahawa esok mungkin lebih baik daripada hari ini.",
  "ending_outlookExtinction": "Tiada siapa yang berkabung atas ketiadaan koloni di {planetName}. Planet itu terus berputar perlahan, acuh terhadap percikan kehidupan ringkas yang pernah berkelip dan padam di permukaannya.",
  "ending_outlookDefault": "Kisah koloni di {planetName} baru sahaja bermula.",
