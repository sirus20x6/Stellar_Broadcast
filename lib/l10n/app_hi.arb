  "ending_titleGoldenAge": "{planetName} का प्रथम पुष्पन",
  "ending_titleThrivingColony": "{planetName} पर गहरी जड़ें",
  "ending_titleSurvival": "{planetName} पर कठिनाई से जीती पकड़",
  "ending_titleStruggling": "{planetName} पर पतली मिट्टी",
