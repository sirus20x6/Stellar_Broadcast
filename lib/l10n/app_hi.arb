  "ending_govSentenceDemocracy": "{planetName} के उपनिवेशियों ने लोकतांत्रिक सरकार स्थापित की, निर्वाचित प्रतिनिधि नई सभ्यता को उसके निर्माणकारी वर्षों में मार्गदर्शन करते।",
  "ending_govSentenceTechnocracy": "{planetName} पर शक्ति उन इंजीनियरों और वैज्ञानिकों के हाथ आई जिन्होंने बस्ती को जीवित रखा, विशेषज्ञता और व्यावहारिकता से शासन करती तकनीकी परिषद बनाते हुए।",
  "ending_govSentenceRepublic": "{planetName} पर पहले वर्ष में एक गणतांत्रिक चार्टर लिखा गया, उपनिवेशियों की आवाज़ों को नियुक्त नेताओं की सभा से संतुलित करता।",
  "ending_govSentenceAutocracy": "सांस्कृतिक संस्थानों के खंडहर में, {planetName} पर अधिकार एक शक्तिशाली नेता के तहत केंद्रित हुआ जिसने आवश्यकता और इच्छाशक्ति से व्यवस्था लागू की।",
  "ending_govSentenceTribalCouncil": "{planetName} पर मुट्ठीभर बचे लोगों ने छोटे कुलों में संगठित होकर साझा अग्नि के चारों ओर बुज़ुर्गों की परिषद द्वारा निर्णय लिए।",
  "ending_govSentenceDefault": "{planetName} के उपनिवेशियों ने जैसा बन सका वैसा स्वयं को संगठित किया।",
  "ending_constructionSentenceAdvanced": "उन्नत निर्माण तंत्रों ने {colonyName} के उपनिवेशियों को अवतरण के सप्ताहों में स्थायी संरचनाएँ खड़ी करने दीं, दबावित आवास और अवसंरचना सहित।",
  "ending_constructionSentenceFunctional": "बस्ती के निर्माण उपकरण, पिटे पर कार्यशील, ने बसावट भर में मज़बूत आश्रय और बुनियादी सड़कें बनाईं।",
  "ending_constructionSentencePrimitive": "निर्माण तंत्र मुश्किल से कार्यशील होने पर बसने वालों ने बचाए ढाँचा खोल और स्थानीय सामग्री से कच्चे आश्रय बनाए।",
  "ending_constructionSentenceNone": "काम करते निर्माण उपकरणों बिना, उपनिवेशी यान के मलबे में सिमटे, कुछ नया बनाने में असमर्थ।",
  "ending_constructionSentenceDefault": "उपनिवेशियों ने जो था उससे जो बन सका बनाया।",
  "ending_moonMetalRichLowRes": "ऊपर कक्षा में धातु-समृद्ध चंद्रमा बस्ती का उद्धार बना — इसकी सतह पर खनन अभियानों ने वह कच्चा माल दिया जो ग्रह स्वयं नहीं दे सका।",
  "ending_moonMetalRichHighRes": "ग्रह के धातु-समृद्ध चंद्रमा ने पहले से पर्याप्त खनिज संसाधनों को स्वागत योग्य पूरक दिया, तीव्र तकनीकी उन्नति को ईंधन देते हुए।",
  "ending_moonUnstable": "क्षयशील कक्षा में अस्थिर चंद्रमा ने बस्ती पर मलबा बरसाया, अवसंरचना तबाह की और समय-समय पर उल्का बमबारी में अपूरणीय तकनीक नष्ट की।",
  "ending_culturePhrase_renaissance": "पृथ्वी की कलात्मक और साहित्यिक परंपराएँ न केवल बचीं बल्कि पुनर्जागरण में खिलीं",
  "ending_culturePhrase_preserved": "उपनिवेशियों ने पृथ्वी की अधिकांश सांस्कृतिक विरासत संरक्षित की, पुस्तकालय और परंपराएँ बनाए रखते हुए",
  "ending_culturePhrase_fragmented": "पृथ्वी की संस्कृति के केवल टुकड़े बचे — आधे-याद गीत और कहानियाँ मौखिक रूप से आगे बढ़ीं",
  "ending_culturePhrase_lost": "पृथ्वी की संस्कृति लगभग भूल गई, जीवन रक्षा की क्रूर व्यावहारिकता द्वारा प्रतिस्थापित",
  "ending_culturePhrase_default": "पृथ्वी की सांस्कृतिक विरासत ने नया रूप लिया",
  "ending_techPhrase_advanced": "जबकि यान की उन्नत तकनीक ने बस्ती को बिजली, चिकित्सा और संचार तंत्र के साथ आधुनिक सभ्यता बनाने दी।",
  "ending_techPhrase_industrial": "और बस्ती ने औद्योगिक स्तर की तकनीक प्राप्त की, भट्टियाँ, चक्कियाँ और बुनियादी निर्माण बढ़ती जनसंख्या को बनाए रखते।",
  "ending_techPhrase_preIndustrial": "हालाँकि तकनीक पूर्व-औद्योगिक अवस्था में लौट गई, हस्त उपकरण और पशु श्रम दैनिक जीवन की रीढ़ बने।",
  "ending_techPhrase_stoneAge": "और पुनर्निर्माण के साधन बिना, बस्ती पाषाण-युगीन अस्तित्व में फिसल गई, चट्टान और हड्डी से उपकरण तराशती।",
  "ending_techPhrase_default": "और तकनीक उस स्तर पर स्थिर हुई जो उपनिवेशी बनाए रख सकते थे।",
  "ending_populationHigh": "लगभग सभी {colonists} उपनिवेशी यात्रा में बचे, {colonyName} को मानव पूंजी की मज़बूत नींव देते।",
  "ending_populationMedium": "मूल हज़ार में से {colonists} उपनिवेशी {colonyName} पहुँचे — व्यवहार्य जनसंख्या बनाए रखने के लिए पर्याप्त।",
  "ending_populationLow": "केवल {colonists} उपनिवेशी {colonyName} पहुँचे, नई सभ्यता के लिए खतरनाक रूप से छोटा जीन पूल।",
  "ending_populationCritical": "मात्र {colonists} आत्माएँ {colonyName} पहुँचीं — बस्ती कहलाने के लिए मुश्किल से पर्याप्त, अधिक एक बेताब अंतिम मोर्चा।",
  "ending_nativeSentenceIntegrated": "{planetName} के मूल निवासियों ने बसने वालों का स्वागत किया, और एक पीढ़ी में दोनों लोग एक साझा समाज में विलीन हो गए, परंपराओं के मिश्रण से समृद्ध।",
  "ending_nativeSentenceCoexistence": "उपनिवेशियों और {planetName} के मूल निवासियों ने सतर्क पर शांतिपूर्ण सह-अस्तित्व बनाए रखा, सांस्कृतिक सीमाओं के पार ज्ञान और संसाधन बाँटते।",
  "ending_nativeSentenceTension": "{planetName} के मूल निवासियों से संबंध तनावपूर्ण रहे, गलतफ़हमियों और क्षेत्रीय विवादों ने बस्ती के भविष्य पर छाया डाली।",
  "ending_nativeSentenceConflict": "{planetName} की मूल सभ्यता से खुला संघर्ष बस्ती के प्रारंभिक इतिहास की पहचान बना, दोनों पक्षों से संसाधन और जीवन खींचता एक ऐसे संघर्ष में जो कोई वास्तव में जीत नहीं सकता था।",
  "ending_outlookGoldenAge": "{planetName} पर अकेले और संघर्ष से मुक्त, बस्ती ने तारों में एक उज्ज्वल भविष्य की ओर अपना मार्ग बनाया।",
  "ending_outlookThrivingColony": "बिना मूल प्रतिस्पर्धा, उपनिवेशी {planetName} की सतह पर फैले, कस्बे और सड़कें बनाते जो बसावटों के बढ़ते जाल को जोड़तीं।",
  "ending_outlookSurvival": "खाली ग्रह ने न सहयोगी दिए न शत्रु, और उपनिवेशियों ने {planetName} के विशाल भूदृश्य के मौन में अपनी जगह तराशी।",
  "ending_outlookStruggling": "{planetName} के बंजर एकांत ने उपनिवेशियों को न सहायता दी न सांत्वना, केवल एक अपरिचित ग्रह का उदासीन मौन।",
  "ending_outlookDire": "अन्य बुद्धिमान जीवन से रहित ग्रह पर, अंतिम बचे लोगों के पास केवल एक-दूसरे और मिटती आशा थी कि कल आज से कोमल हो।",
  "ending_outlookExtinction": "{planetName} पर बस्ती के अंत पर किसी ने शोक नहीं मनाया। ग्रह बस अपने धीमे घूर्णन में जारी रहा, अपनी सतह पर झिलमिलाई और बुझी जीवन की संक्षिप्त चिंगारी के प्रति उदासीन।",
  "ending_outlookDefault": "{planetName} पर बस्ती की कहानी अभी शुरू ही हुई थी।",
